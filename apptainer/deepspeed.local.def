Bootstrap: localimage
From: base_pytorch.sif

%files
    requirements.common.txt /opt/brisk/requirements.common.txt
    requirements.torch.txt /opt/brisk/requirements.torch.txt
    requirements.deepspeed.txt /opt/brisk/requirements.deepspeed.txt

%post
    set -e
    apt-get update
    apt-get install -y --no-install-recommends git build-essential ninja-build
    rm -rf /var/lib/apt/lists/*

    pip install --no-cache-dir -r /opt/brisk/requirements.common.txt -r /opt/brisk/requirements.torch.txt
    DS_BUILD_OPS=1 pip install --no-cache-dir -r /opt/brisk/requirements.deepspeed.txt

%environment
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1

%runscript
    cd /workspace
    exec python main.py --entry train --backend deepspeed --config train/config.yaml "$@"
